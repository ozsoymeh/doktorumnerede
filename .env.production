PORT=3001
NODE_ENV=production

# Session Secret für Express Session
SESSION_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_STRING

# Admin Zugangsdaten
ADMIN_EMAIL=CHANGE_THIS_TO_YOUR_ADMIN_EMAIL
ADMIN_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD

# Upload Einstellungen
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif 